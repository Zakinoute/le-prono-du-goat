# ============================================================
# Le Prono du GOAT — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# ============================================================

# ---------- Supabase ----------
# Dashboard Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé serveur uniquement — JAMAIS exposée au client (contourne la RLS).
SUPABASE_SERVICE_ROLE_KEY=

# ---------- App ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- API-Football (scores live, via Make) ----------
# https://www.api-football.com/
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ---------- IA (profils IA des joueurs + résumé IA de la journée) ----------
# On utilise Groq et/ou Gemini (gratuits) plutôt qu'Anthropic (payant).
# Il suffit d'UNE des deux clés pour activer les features IA.
#   Groq   : https://console.groq.com/keys  (compatible OpenAI, rapide)
#   Gemini : https://aistudio.google.com/app/apikey
GROQ_API_KEY=
GEMINI_API_KEY=
# Optionnel : forcer un provider (groq|gemini) ou un modèle.
# AI_PROVIDER=groq
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.0-flash
# Anthropic non utilisé (clé payante) — laissé pour compat éventuelle.
ANTHROPIC_API_KEY=

# ---------- Make (orchestration) ----------
# Secret partagé pour sécuriser les webhooks appelés par Make.
MAKE_WEBHOOK_SECRET=

# ---------- Bot Discord (Bonus 1) ----------
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ---------- Jobs / Cron (protection des routes serveur) ----------
CRON_SECRET=
